#!/bin/sh
# Strip Cursor attribution trailers before a commit is finalized.

MSG_FILE="$1"
[ -f "$MSG_FILE" ] || exit 0

tmp="${MSG_FILE}.cursor-strip.$$"
grep -v -E '^(Co-authored-by: Cursor( Agent)? <cursoragent@cursor.com>|Co-authored-by: Cursor|Made-with: Cursor|Made with Cursor)$' \
  "$MSG_FILE" > "$tmp" && mv "$tmp" "$MSG_FILE"
